#统计分析模块

class StatisticsManager:
    def __init__(self, student_manager, score_manager):
        self.student_manager = student_manager
        self.score_manager = score_manager

    def calculate_average(self, scores):
        """计算平均分"""
        if not scores:
            return 0
        return sum(scores) / len(scores)

    def get_student_average(self, student_id):
        """获取单个学生的平均分"""
        if student_id not in self.score_manager.scores:
            return None
        scores = list(self.score_manager.scores[student_id].values())
        return self.calculate_average(scores)

    def get_course_average(self, course):
        """获取某门课程的平均分"""
        scores = []
        for student_scores in self.score_manager.scores.values():
            if course in student_scores:
                scores.append(student_scores[course])
        if not scores:
            return None
        return self.calculate_average(scores)

    def get_class_average(self, clazz):
        """获取某班级的平均分"""
        all_scores = []
        for student_id, student in self.student_manager.students.items():
            if student['class'] == clazz and student_id in self.score_manager.scores:
                all_scores.extend(list(self.score_manager.scores[student_id].values()))
        if not all_scores:
            return None
        return self.calculate_average(all_scores)

    def analyze_student_performance(self):
        """分析学生个人成绩"""
        student_id = input("请输入学生学号: ").strip()
        if student_id not in self.student_manager.students:
            print("错误：该学生不存在！")
            return
        
        student = self.student_manager.students[student_id]
        avg_score = self.get_student_average(student_id)
        
        print(f"\n----- {student['name']}的成绩分析 -----")
        print(f"学号: {student_id}")
        print(f"班级: {student['class']}")
        
        if avg_score is None:
            print("暂无成绩记录")
            return
        
        print(f"平均分: {avg_score:.2f}")
        
        if avg_score >= 90:
            level = "优秀"
        elif avg_score >= 80:
            level = "良好"
        elif avg_score >= 60:
            level = "及格"
        else:
            level = "不及格"
        
        print(f"成绩等级: {level}")
        
        if student_id in self.score_manager.scores:
            print("\n各科成绩详情:")
            for course, score in self.score_manager.scores[student_id].items():
                print(f"  {course}: {score}")

    def analyze_course_statistics(self):
        """分析课程成绩统计"""
        print("\n可选课程：")
        for i, course in enumerate(self.score_manager.courses, 1):
            print(f"{i}. {course}")
        
        choice = get_valid_input("请选择课程(1-4): ", int, range(1, 5))
        course = self.score_manager.courses[choice - 1]
        
        avg_score = self.get_course_average(course)
        
        print(f"\n----- {course}课程统计 -----")
        if avg_score is None:
            print("暂无该课程成绩记录")
            return
        
        print(f"课程平均分: {avg_score:.2f}")
        
        scores = []
        for student_scores in self.score_manager.scores.values():
            if course in student_scores:
                scores.append(student_scores[course])
        
        if scores:
            print(f"最高分: {max(scores):.2f}")
            print(f"最低分: {min(scores):.2f}")
            print(f"参考人数: {len(scores)}")

    def analyze_class_statistics(self):
        """分析班级成绩统计"""
        classes = set()
        for student in self.student_manager.students.values():
            classes.add(student['class'])
        
        if not classes:
            print("暂无班级信息！")
            return
        
        print("\n可选班级：")
        class_list = sorted(list(classes))
        for i, clazz in enumerate(class_list, 1):
            print(f"{i}. {clazz}")
        
        choice = get_valid_input("请选择班级(1-{0}): ".format(len(class_list)), int, range(1, len(class_list) + 1))
        clazz = class_list[choice - 1]
        
        avg_score = self.get_class_average(clazz)
        
        print(f"\n----- {clazz}班级统计 -----")
        if avg_score is None:
            print("暂无该班级成绩记录")
            return
        
        print(f"班级平均分: {avg_score:.2f}")
        
        class_students = [sid for sid, s in self.student_manager.students.items() if s['class'] == clazz]
        print(f"班级人数: {len(class_students)}")
        
        scored_students = [sid for sid in class_students if sid in self.score_manager.scores]
        print(f"有成绩记录人数: {len(scored_students)}")

    def analyze_gender_statistics(self):
        """分析不同性别成绩差异"""
        male_scores = []
        female_scores = []
        
        for student_id, student in self.student_manager.students.items():
            if student_id in self.score_manager.scores:
                scores = list(self.score_manager.scores[student_id].values())
                if student['gender'] == '男':
                    male_scores.extend(scores)
                else:
                    female_scores.extend(scores)
        
        print("\n----- 性别成绩差异分析 -----")
        
        male_avg = self.calculate_average(male_scores) if male_scores else None
        female_avg = self.calculate_average(female_scores) if female_scores else None
        
        print(f"男生人数: {len([s for s in self.student_manager.students.values() if s['gender'] == '男'])}")
        print(f"女生人数: {len([s for s in self.student_manager.students.values() if s['gender'] == '女'])}")
        
        if male_avg is not None:
            print(f"男生平均分: {male_avg:.2f}")
        else:
            print("男生平均分: 暂无数据")
        
        if female_avg is not None:
            print(f"女生平均分: {female_avg:.2f}")
        else:
            print("女生平均分: 暂无数据")
        
        if male_avg is not None and female_avg is not None:
            diff = male_avg - female_avg
            if diff > 0:
                print(f"男生平均分比女生高 {abs(diff):.2f} 分")
            elif diff < 0:
                print(f"女生平均分比男生高 {abs(diff):.2f} 分")
            else:
                print("男女生平均分相同")

    def export_statistics(self):
        """导出统计结果到文件"""
        try:
            with open("statistics_report.txt", "w", encoding="utf-8") as f:
                f.write("===== 学生成绩统计报告 =====\n\n")
                
                f.write("一、各课程平均分\n")
                for course in self.score_manager.courses:
                    avg = self.get_course_average(course)
                    f.write(f"  {course}: {avg:.2f}\n" if avg else f"  {course}: 暂无数据\n")
                
                f.write("\n二、各班级平均分\n")
                classes = set(s['class'] for s in self.student_manager.students.values())
                for clazz in sorted(classes):
                    avg = self.get_class_average(clazz)
                    f.write(f"  {clazz}: {avg:.2f}\n" if avg else f"  {clazz}: 暂无数据\n")
                
                f.write("\n三、学生个人成绩\n")
                for student_id, student in self.student_manager.students.items():
                    avg = self.get_student_average(student_id)
                    f.write(f"\n  学号: {student_id}, 姓名: {student['name']}, 班级: {student['class']}\n")
                    f.write(f"  平均分: {avg:.2f}\n" if avg else "  平均分: 暂无数据\n")
                    if student_id in self.score_manager.scores:
                        f.write("  各科成绩:\n")
                        for course, score in self.score_manager.scores[student_id].items():
                            f.write(f"    {course}: {score}\n")
            
            print("统计报告已导出到 statistics_report.txt")
        except Exception as e:
            print(f"导出失败: {e}")

    def statistics_menu(self):
        """统计分析子菜单"""
        while True:
            print("\n----- 成绩统计分析 -----")
            print_menu([
                "学生个人成绩分析",
                "课程成绩统计",
                "班级成绩统计",
                "性别成绩差异分析",
                "返回主菜单"
            ])
            
            choice = get_valid_input("请输入您的选择(1-5): ", int, range(1, 6))
            
            if choice == 1:
                self.analyze_student_performance()
            elif choice == 2:
                self.analyze_course_statistics()
            elif choice == 3:
                self.analyze_class_statistics()
            elif choice == 4:
                self.analyze_gender_statistics()
            elif choice == 5:
                break



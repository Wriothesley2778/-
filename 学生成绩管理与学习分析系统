#工具函数模块

def print_menu(options):
    """打印菜单"""
    for i, option in enumerate(options, 1):
        print(f"{i}. {option}")

def get_valid_input(prompt, type_func, valid_range=None):
    """获取合法输入，带异常处理"""
    while True:
        try:
            value = type_func(input(prompt))
            if valid_range and value not in valid_range:
                print(f"输入超出范围，请输入{valid_range.start}到{valid_range.stop-1}之间的数字")
                continue
            return value
        except ValueError:
            print(f"输入格式错误，请输入{type_func.__name__}类型的数据")

def validate_score(score):
    """验证成绩是否在0-100之间"""
    return 0 <= score <= 100


#学生信息管理模块

class StudentManager:
    def __init__(self):
        self.students = {}  # 数据结构：字典，key=学号，value=学生信息字典

    def add_student(self):
        """添加学生信息"""
        student_id = input("请输入学生学号: ").strip()
        if student_id in self.students:
            print("错误：该学号已存在！")
            return
        
        name = input("请输入学生姓名: ").strip()
        if not name:
            print("错误：姓名不能为空！")
            return
        
        clazz = input("请输入学生班级: ").strip()
        gender = input("请输入学生性别(男/女): ").strip()
        if gender not in ["男", "女"]:
            print("错误：性别只能输入男或女！")
            return
        
        self.students[student_id] = {
            "name": name,
            "class": clazz,
            "gender": gender
        }
        print("学生信息添加成功！")

    def delete_student(self):
        """删除学生信息"""
        student_id = input("请输入要删除的学生学号: ").strip()
        if student_id not in self.students:
            print("错误：该学生不存在！")
            return
        
        del self.students[student_id]
        print("学生信息删除成功！")

    def modify_student(self):
        """修改学生信息"""
        student_id = input("请输入要修改的学生学号: ").strip()
        if student_id not in self.students:
            print("错误：该学生不存在！")
            return
        
        student = self.students[student_id]
        print(f"当前信息：姓名={student['name']}, 班级={student['class']}, 性别={student['gender']}")
        
        new_name = input("请输入新姓名(不修改请直接回车): ").strip()
        if new_name:
            student["name"] = new_name
        
        new_class = input("请输入新班级(不修改请直接回车): ").strip()
        if new_class:
            student["class"] = new_class
        
        new_gender = input("请输入新性别(男/女，不修改请直接回车): ").strip()
        if new_gender in ["男", "女"]:
            student["gender"] = new_gender
        
        print("学生信息修改成功！")

    def query_student(self):
        """查询学生信息"""
        student_id = input("请输入要查询的学生学号: ").strip()
        if student_id not in self.students:
            print("错误：该学生不存在！")
            return
        
        student = self.students[student_id]
        print("\n----- 学生信息 -----")
        print(f"学号: {student_id}")
        print(f"姓名: {student['name']}")
        print(f"班级: {student['class']}")
        print(f"性别: {student['gender']}")

    def show_all_students(self):
        """显示所有学生信息"""
        if not self.students:
            print("暂无学生信息！")
            return
        
        print("\n----- 所有学生信息 -----")
        print(f"{'学号':<12}{'姓名':<8}{'班级':<12}{'性别':<4}")
        print("-" * 36)
        for student_id, info in self.students.items():
            print(f"{student_id:<12}{info['name']:<8}{info['class']:<12}{info['gender']:<4}")

    def student_menu(self):
        """学生信息管理子菜单"""
        while True:
            print("\n----- 学生信息管理 -----")
            print_menu([
                "添加学生信息",
                "删除学生信息",
                "修改学生信息",
                "查询学生信息",
                "显示所有学生",
                "返回主菜单"
            ])
            
            choice = get_valid_input("请输入您的选择(1-6): ", int, range(1, 7))
            
            if choice == 1:
                self.add_student()
            elif choice == 2:
                self.delete_student()
            elif choice == 3:
                self.modify_student()
            elif choice == 4:
                self.query_student()
            elif choice == 5:
                self.show_all_students()
            elif choice == 6:
                break


#成绩管理模块

class ScoreManager:
    def __init__(self):
        self.scores = {}  # 数据结构：字典，key=学号，value=课程成绩字典
        self.courses = ["Python程序设计", "高等数学", "大学英语", "数据结构"]

    def add_score(self, student_manager):
        """添加学生成绩"""
        student_id = input("请输入学生学号: ").strip()
        if student_id not in student_manager.students:
            print("错误：该学生不存在！")
            return
        
        if student_id not in self.scores:
            self.scores[student_id] = {}
        
        print("\n可选课程：")
        for i, course in enumerate(self.courses, 1):
            print(f"{i}. {course}")
        
        course_choice = get_valid_input("请选择课程(1-4): ", int, range(1, 5))
        course = self.courses[course_choice - 1]
        
        if course in self.scores[student_id]:
            print(f"警告：该学生已有{course}成绩，将覆盖原有成绩")
        
        score = get_valid_input("请输入成绩(0-100): ", float)
        if not validate_score(score):
            print("错误：成绩必须在0-100之间！")
            return
        
        self.scores[student_id][course] = score
        print("成绩添加成功！")

    def delete_score(self, student_manager):
        """删除学生成绩"""
        student_id = input("请输入学生学号: ").strip()
        if student_id not in student_manager.students:
            print("错误：该学生不存在！")
            return
        
        if student_id not in self.scores or not self.scores[student_id]:
            print("错误：该学生暂无成绩记录！")
            return
        
        print("\n该学生成绩：")
        courses = list(self.scores[student_id].keys())
        for i, course in enumerate(courses, 1):
            print(f"{i}. {course}: {self.scores[student_id][course]}")
        
        course_choice = get_valid_input("请选择要删除的课程(1-{0}): ".format(len(courses)), int, range(1, len(courses) + 1))
        course = courses[course_choice - 1]
        
        del self.scores[student_id][course]
        if not self.scores[student_id]:
            del self.scores[student_id]
        
        print("成绩删除成功！")

    def modify_score(self, student_manager):
        """修改学生成绩"""
        student_id = input("请输入学生学号: ").strip()
        if student_id not in student_manager.students:
            print("错误：该学生不存在！")
            return
        
        if student_id not in self.scores or not self.scores[student_id]:
            print("错误：该学生暂无成绩记录！")
            return
        
        print("\n该学生成绩：")
        courses = list(self.scores[student_id].keys())
        for i, course in enumerate(courses, 1):
            print(f"{i}. {course}: {self.scores[student_id][course]}")
        
        course_choice = get_valid_input("请选择要修改的课程(1-{0}): ".format(len(courses)), int, range(1, len(courses) + 1))
        course = courses[course_choice - 1]
        
        new_score = get_valid_input("请输入新成绩(0-100): ", float)
        if not validate_score(new_score):
            print("错误：成绩必须在0-100之间！")
            return
        
        self.scores[student_id][course] = new_score
        print("成绩修改成功！")

    def query_score(self, student_manager):
        """查询学生成绩"""
        student_id = input("请输入学生学号: ").strip()
        if student_id not in student_manager.students:
            print("错误：该学生不存在！")
            return
        
        if student_id not in self.scores or not self.scores[student_id]:
